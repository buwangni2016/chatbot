# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# === Optional: Code Sandbox (for execute-code tool) ===
# Leave blank to disable code sandbox. Set all 3 to enable.
VERCEL_TOKEN=****
VERCEL_TEAM_ID=****
VERCEL_PROJECT_ID=****

# === Optional: Direct API keys (fallback if AI_GATEWAY_API_KEY not set) ===
# If AI_GATEWAY_API_KEY is set, Vercel AI Gateway routes requests automatically.
# Direct keys below are used as fallback.

# Anthropic
ANTHROPIC_API_KEY=****
# ANTHROPIC_BASE_URL=https://your-proxy.com/v1 (optional, for China users)

# OpenAI
OPENAI_API_KEY=****
# OPENAI_BASE_URL=https://your-proxy.com/v1 (optional)

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=****
# GOOGLE_GENERATIVE_AI_BASE_URL=https://your-proxy.com/v1beta (optional)

# xAI
XAI_API_KEY=****
# XAI_BASE_URL=https://your-proxy.com/v1 (optional)
